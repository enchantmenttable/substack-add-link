{
  "manifest_version": 3,
  "name": "Substack Internal Linking",
  "version": "1.0.0",
  "description": "Insert links to your Substack posts using [[wiki-link syntax",
  "permissions": ["storage", "unlimitedStorage"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://*.substack.com/*"],
      "js": ["content_script.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
